<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Suba Hotels – Deep Dive</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* Vibrant Luxury Hotel Theme */
  --bg-gradient: linear-gradient(135deg, #061121 0%, #0f2c4b 50%, #071b36 100%);
  
  /* Bright, Vibrant Accents */
  --accent-gold: #FFD700;       /* Brilliant Gold */
  --accent-gold-light: #FFE866; 
  --accent-teal: #00E5FF;       /* Vibrant Aqua/Cyan */
  --accent-red: #FF4D4D;        /* Bright Coral Red */
  --accent-blue: #4DACFF;       /* Vibrant Sky Blue */
  
  /* High Contrast Text */
  --text-heading: #FFFFFF;
  --text-primary: #F8FAFC;
  --text-secondary: #CBD5E1;
  --text-dim: #94A3B8;
  
  /* Glassmorphism Cards */
  --bg-card: rgba(15, 23, 42, 0.65);
  --bg-card-hover: rgba(30, 41, 59, 0.85);
  --border: rgba(255, 215, 0, 0.25); 
  --border-bright: rgba(255, 215, 0, 0.6);
  --glass-nav: rgba(6, 17, 33, 0.85);
  
  --shadow-glow: 0 8px 24px rgba(0, 229, 255, 0.08);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Outfit', sans-serif;
  background: var(--bg-gradient);
  background-attachment: fixed;
  color: var(--text-primary);
  font-size: 15px; /* Scaled back base font */
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ─── VIBRANT AMBIENT LIGHTING (BACKGROUND) ─── */
.ambient-glow-1 {
  position: fixed; top: -10%; left: -10%; width: 50vw; height: 50vw;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.1) 0%, transparent 60%);
  pointer-events: none; z-index: -1; filter: blur(40px);
}
.ambient-glow-2 {
  position: fixed; bottom: -20%; right: -10%; width: 60vw; height: 60vw;
  background: radial-gradient(circle, rgba(0, 229, 255, 0.06) 0%, transparent 60%);
  pointer-events: none; z-index: -1; filter: blur(50px);
}

/* ─── NAV ─── */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: var(--glass-nav);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  display: flex; align-items: center; justify-content: space-between;
  height: 64px;
  transition: transform .3s;
}
.nav.hidden { transform: translateY(-100%); }
.nav-brand {
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  color: var(--accent-gold);
  letter-spacing: 1px;
  flex-shrink: 0;
}
.nav-links { display: flex; gap: 6px; overflow-x: auto; scrollbar-width: none; align-items: center; }
.nav-links::-webkit-scrollbar { display: none; }
.nav-link {
  padding: 8px 12px; border-radius: 6px;
  font-size: 13px; font-weight: 500;
  color: var(--text-secondary);
  text-decoration: none;
  white-space: nowrap;
  transition: all .2s;
  cursor: pointer;
}
.nav-link:hover, .nav-link.active { 
  color: var(--bg-card); 
  background: var(--accent-gold); 
  font-weight: 600;
}

.hamburger {
  display: none; flex-direction: column; gap: 5px; cursor: pointer;
  padding: 8px;
}
.hamburger span { width: 24px; height: 2px; background: var(--accent-gold); transition: .3s; }

/* ─── SLIDES ─── */
.slide {
  min-height: 100vh;
  padding: 100px 24px 60px;
  display: flex; flex-direction: column; justify-content: center;
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
}

.slide-label {
  font-size: 14px; font-weight: 600;
  color: var(--accent-gold);
  text-transform: uppercase;
  letter-spacing: 3px;
  margin-bottom: 16px;
  opacity: 0; transform: translateY(20px);
  transition: all .6s ease;
}
.slide-label.visible { opacity: 1; transform: none; }
.slide-label::before {
  content: ''; display: inline-block; width: 24px; height: 2px;
  background: var(--accent-gold); vertical-align: middle; margin-right: 12px;
}

.slide-title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(32px, 5vw, 56px);
  line-height: 1.1;
  margin-bottom: 20px;
  color: var(--text-heading);
  opacity: 0; transform: translateY(30px);
  transition: all .7s ease .1s;
}
.slide-title.visible { opacity: 1; transform: none; }
.slide-title .gold { color: var(--accent-gold); }
.slide-title .teal { color: var(--accent-teal); }

.slide-subtitle {
  font-size: clamp(16px, 2vw, 18px); 
  color: var(--text-secondary);
  line-height: 1.7; max-width: 800px;
  margin-bottom: 40px;
  font-weight: 400;
  opacity: 0; transform: translateY(20px);
  transition: all .6s ease .2s;
}
.slide-subtitle.visible { opacity: 1; transform: none; }

/* ─── CARDS / GRIDS ─── */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  gap: 20px;
  margin-top: 20px;
}
.card {
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 24px;
  box-shadow: var(--shadow-glow);
  transition: all .4s cubic-bezier(0.25, 1, 0.5, 1);
  opacity: 0; transform: translateY(25px);
}
.card.visible { opacity: 1; transform: none; }
.card:hover { 
  background: var(--bg-card-hover); 
  border-color: var(--border-bright); 
  transform: translateY(-4px) !important; 
}
.card-icon {
  width: 44px; height: 44px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  margin-bottom: 16px;
  background: rgba(255, 215, 0, 0.1);
  border: 1px solid var(--border);
}
.card-title {
  font-family: 'DM Serif Display', serif;
  font-size: 20px; 
  margin-bottom: 10px;
  color: var(--accent-gold-light);
}
.card-body { font-size: 14px; color: var(--text-secondary); line-height: 1.6; font-weight: 400; }

/* ─── METRIC BOXES ─── */
.metrics-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 16px;
  margin: 32px 0;
}
.metric-box {
  background: var(--bg-card);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 24px 16px;
  text-align: center;
  opacity: 0; transform: scale(0.95);
  transition: all .5s;
}
.metric-box.visible { opacity: 1; transform: none; }
.metric-value {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(28px, 4vw, 42px);
  color: var(--accent-gold);
  line-height: 1;
}
.metric-value.teal { color: var(--accent-teal); }
.metric-value.blue { color: var(--accent-blue); }
.metric-label {
  font-size: 12px; color: var(--text-primary);
  margin-top: 10px; text-transform: uppercase;
  letter-spacing: 1px; font-weight: 600;
}

/* ─── TIMELINE ─── */
.timeline { position: relative; margin: 32px 0; padding-left: 32px; }
.timeline::before {
  content: ''; position: absolute; left: 8px; top: 0; bottom: 0;
  width: 2px; background: linear-gradient(to bottom, var(--accent-gold), transparent);
}
.tl-item {
  position: relative; margin-bottom: 28px;
  opacity: 0; transform: translateX(-20px);
  transition: all .5s;
}
.tl-item.visible { opacity: 1; transform: none; }
.tl-item::before {
  content: ''; position: absolute; left: -30px; top: 6px;
  width: 12px; height: 12px; border-radius: 50%;
  background: var(--accent-gold);
  border: 3px solid #061121;
  box-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
}
.tl-date {
  font-size: 13px; color: var(--accent-gold);
  margin-bottom: 6px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;
}
.tl-text { font-size: 15px; color: var(--text-secondary); line-height: 1.6; font-weight: 400; }

/* ─── PRICE CHART ─── */
.price-chart-container {
  background: var(--bg-card); backdrop-filter: blur(16px); border: 1px solid var(--border);
  border-radius: 10px; padding: 24px; margin: 28px 0;
  position: relative; overflow: hidden;
  box-shadow: var(--shadow-glow);
}

/* ─── QUOTE ─── */
.quote-block {
  position: relative;
  padding: 28px 32px;
  background: linear-gradient(90deg, rgba(255,215,0,0.1), transparent);
  border-left: 4px solid var(--accent-gold);
  border-radius: 0 10px 10px 0;
  margin: 32px 0;
  font-style: italic;
  color: var(--text-primary);
  font-size: clamp(16px, 2vw, 18px);
  line-height: 1.7;
  font-family: 'DM Serif Display', serif;
}
.quote-attr { 
  font-style: normal; color: var(--accent-gold); 
  font-size: 13px; margin-top: 16px; 
  font-family: 'Outfit', sans-serif; font-weight: 600;
  text-transform: uppercase; letter-spacing: 1px;
}

/* ─── TABLE ─── */
.data-table {
  width: 100%; border-collapse: collapse;
  margin: 24px 0; font-size: 14px;
}
.data-table th {
  text-align: left; padding: 14px;
  font-size: 13px; text-transform: uppercase;
  letter-spacing: 1px; color: var(--accent-gold);
  border-bottom: 1px solid var(--border-bright);
  font-weight: 600;
}
.data-table td {
  padding: 14px;
  border-bottom: 1px solid rgba(255, 215, 0, 0.15);
  color: var(--text-secondary);
}
.data-table tr:hover td { background: rgba(255, 215, 0, 0.08); color: var(--text-primary); }
.data-table .num { font-variant-numeric: tabular-nums; font-weight: 500; text-align: right; }
.data-table .highlight { color: var(--accent-teal); font-weight: 700; }

/* ─── PROGRESS BAR ─── */
.progress-item { margin: 16px 0; }
.progress-label { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 8px; font-weight: 500; color: var(--text-primary); }
.progress-label span:last-child { color: var(--accent-gold); font-weight: 700; }
.progress-track {
  height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;
}
.progress-fill {
  height: 100%; border-radius: 3px;
  background: linear-gradient(90deg, var(--accent-gold), var(--accent-teal));
  width: 0; transition: width 1.5s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
}

/* ─── SME GEMS BADGE ─── */
.sme-badge {
  display: inline-flex; align-items: center; gap: 10px;
  background: rgba(255, 215, 0, 0.15);
  border: 1px solid var(--accent-gold);
  padding: 10px 20px; border-radius: 6px;
  font-size: 13px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
  color: var(--accent-gold-light);
  margin: 10px 0 24px;
  box-shadow: 0 4px 15px rgba(255, 215, 0, 0.15);
}

/* ─── TOOLTIP ─── */
.chart-tooltip {
  position: absolute;
  background: var(--glass-nav);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-bright);
  border-radius: 6px;
  padding: 12px 16px;
  font-size: 13px;
  color: var(--text-primary);
  pointer-events: none;
  z-index: 10;
  display: none;
  min-width: 180px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}
.chart-tooltip .tt-date { font-size: 14px; font-weight: 700; text-transform: uppercase; color: var(--accent-gold); margin-bottom: 8px; border-bottom: 1px solid var(--border); padding-bottom: 6px;}
.chart-tooltip .tt-row { display: flex; justify-content: space-between; gap: 16px; margin-bottom: 4px;}
.chart-tooltip .tt-label { color: var(--text-dim); }
.chart-tooltip .tt-val { font-weight: 600; }

/* ─── FOOTER ─── */
.footer-bar {
  text-align: center; padding: 48px 24px;
  border-top: 1px solid rgba(255, 215, 0, 0.2);
  font-size: 14px; color: var(--text-dim); font-weight: 400;
  background: rgba(6, 17, 33, 0.95);
}
.footer-bar a {
  color: var(--accent-gold); text-decoration: none;
  display: inline-flex; align-items: center; gap: 6px;
  font-weight: 600; text-transform: uppercase; letter-spacing: 1px;
}

/* ─── SLIDE COUNTER ─── */
.slide-counter {
  position: fixed; bottom: 20px; right: 20px;
  background: var(--glass-nav); backdrop-filter: blur(12px); border: 1px solid var(--border-bright);
  border-radius: 6px; padding: 8px 16px;
  font-weight: 600; font-size: 13px; color: var(--accent-gold);
  z-index: 90;
  box-shadow: 0 4px 15px rgba(0,0,0,0.25);
}

/* ─── RESPONSIVE ─── */
@media (max-width: 768px) {
  .slide { padding: 90px 20px 50px; }
  .nav-brand { font-size: 18px; }
  .nav-links { display: none; }
  .nav-links.open { display: flex; flex-direction: column; position: absolute; top: 64px; left: 0; right: 0; background: #061121; padding: 16px; border-bottom: 1px solid var(--border); z-index: 200; box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
  .nav-link { font-size: 15px; width: 100%; text-align: center; padding: 12px; }
  .hamburger { display: flex; }
  .card-grid { grid-template-columns: 1fr; }
  .metrics-row { grid-template-columns: repeat(2, 1fr); }
  .data-table { font-size: 12px; }
  .data-table th, .data-table td { padding: 10px 8px; }
}
@media (max-width: 480px) {
  .metrics-row { grid-template-columns: 1fr 1fr; }
  .metric-value { font-size: 28px; }
  .price-chart-container { padding: 16px; }
}
</style>
</head>
<body>

<div class="ambient-glow-1"></div>
<div class="ambient-glow-2"></div>

<nav class="nav" id="nav">
  <div class="nav-brand">SUBA HOTELS</div>
  <div class="nav-links" id="navLinks">
