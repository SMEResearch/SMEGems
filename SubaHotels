  {date:'27-Mar-26',close:109.00,high:114.05,low:108.00,vol:229200},
  {date:'30-Mar-26',close:100.95,high:107.00,low:97.65,vol:177600},
  {date:'01-Apr-26',close:107.80,high:111.80,low:105.00,vol:82800},
  {date:'02-Apr-26',close:110.40,high:113.00,low:103.00,vol:36000},
  {date:'06-Apr-26',close:120.05,high:121.50,low:111.00,vol:79200},
  {date:'07-Apr-26',close:124.60,high:126.80,low:120.00,vol:100800},
];

function drawPriceChart() {
  const canvas = document.getElementById('priceCanvas');
  if (!canvas) return;
  const container = canvas.parentElement;
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const W = container.clientWidth - 48;
  const H = 280; 
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  ctx.scale(dpr, dpr);

  const isMobile = W < 500;

  const pad = {
      top: isMobile ? 55 : 75, 
      right: isMobile ? 35 : 50, 
      bottom: isMobile ? 55 : 65, 
      left: 15
  }; 
  
  const cW = W - pad.left - pad.right;
  const cH = H - pad.top - pad.bottom;
  const n = priceData.length;

  const allLows = priceData.map(d => d.low);
  const allHighs = priceData.map(d => d.high);
  
  const minP = Math.min(...allLows) - 20;
  const maxP = Math.max(...allHighs) + 50; 

  const toX = i => pad.left + (i / (n - 1)) * cW;
  const toY = p => pad.top + (1 - (p - minP) / (maxP - minP)) * cH;

  // Grid
  ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)'; ctx.lineWidth = 1;
  for (let p = Math.ceil(minP/20)*20; p <= maxP; p += 20) {
    const y = toY(p);
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W-pad.right, y); ctx.stroke();
    ctx.fillStyle = '#94A3B8'; ctx.font = '11px "Outfit"'; ctx.textAlign = 'right';
    ctx.fillText('₹'+p, W-5, y+4);
  }

  // IPO line
  ctx.strokeStyle = '#FFD700'; ctx.lineWidth = 1.5; ctx.setLineDash([4,4]);
  ctx.beginPath(); ctx.moveTo(pad.left, toY(111)); ctx.lineTo(W-pad.right, toY(111)); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#FFD700'; ctx.font = '600 11px "Outfit"'; ctx.textAlign = 'left';
  ctx.fillText('IPO ₹111', pad.left + 15, toY(111)-6);

  // Area fill
  const grad = ctx.createLinearGradient(0, pad.top, 0, H-pad.bottom);
  grad.addColorStop(0, 'rgba(0, 229, 255, 0.2)');
  grad.addColorStop(1, 'rgba(0, 229, 255, 0)');
  ctx.beginPath();
  ctx.moveTo(toX(0), H-pad.bottom);
  for (let i = 0; i < n; i++) ctx.lineTo(toX(i), toY(priceData[i].close));
  ctx.lineTo(toX(n-1), H-pad.bottom);
  ctx.fillStyle = grad; ctx.fill();

  // Line with color
  for (let i = 1; i < n; i++) {
    ctx.beginPath();
    ctx.moveTo(toX(i-1), toY(priceData[i-1].close));
    ctx.lineTo(toX(i), toY(priceData[i].close));
    ctx.strokeStyle = priceData[i].close >= 111 ? '#00E5FF' : '#FF4D4D';
    ctx.lineWidth = 2.5; ctx.stroke();
  }

  // Volume
  const maxVol = Math.max(...priceData.map(d => d.vol));
  for (let i = 0; i < n; i++) {
    const bh = (priceData[i].vol / maxVol) * 35;
    ctx.fillStyle = priceData[i].close >= 111 ? 'rgba(0, 229, 255, 0.2)' : 'rgba(255, 77, 77, 0.2)';
    ctx.fillRect(toX(i)-1.5, H-pad.bottom-bh, 3, bh);
  }

  // Callouts & Markers - Clean Vertical Architecture
  const peakIdx = priceData.findIndex(d => d.high >= 200);
  const lowIdx = priceData.findIndex(d => d.low <= 97.65);
  
  const mDyTop = isMobile ? -40 : -55;
  const mDyBot = isMobile ? 35 : 45;

  const markers = [
    {idx: 0, label: 'Listed\n₹154.20', c: '#00E5FF', pos: 'bottom', dy: mDyBot},
    {idx: peakIdx, label: 'Peak\n₹200.00', c: '#FFD700', pos: 'top', dy: mDyTop},
    {idx: lowIdx, label: 'Low\n₹97.65', c: '#FF4D4D', pos: 'bottom', dy: mDyBot},
    {idx: n-1, label: 'CMP\n₹124.60', c: '#F8FAFC', pos: 'top', dy: mDyTop}
  ];

  markers.forEach(m => {
    if(m.idx < 0) return;
    const px = toX(m.idx), py = toY(priceData[m.idx].close);
    
    let tx = px;
    let align = 'center';
    
    // Check boundaries dynamically to set alignment
    if (m.idx === 0) { align = 'left'; } 
    else if (m.idx === n - 1) { align = 'right'; }
    
    let ty = py + m.dy; 

    // Draw Connecting Vertical Line
    ctx.beginPath();
    ctx.moveTo(px, py + (m.pos === 'top' ? -7 : 7)); 
    ctx.lineTo(px, ty + (m.pos === 'top' ? 26 : -14)); 
    
    ctx.strokeStyle = m.c;
    ctx.lineWidth = 1.2;
    ctx.globalAlpha = 0.6;
    ctx.stroke();
    ctx.globalAlpha = 1.0;

    // Draw Dot
    ctx.beginPath(); ctx.arc(px, py, 4.5, 0, Math.PI*2);
    ctx.fillStyle = m.c; ctx.fill();
    ctx.strokeStyle = '#0f2c4b'; ctx.lineWidth = 2; ctx.stroke();
    
    // Draw Text
    ctx.fillStyle = m.c; ctx.font = '600 11px "Outfit"'; ctx.textAlign = align;
    m.label.split('\n').forEach((l, i) => {
        ctx.fillText(l, tx, ty + (i * 14));
    });
  });

  // Responsive X Dates - dynamically maps to 3 evenly spaced dates on mobile, 6 on desktop
  ctx.fillStyle='#94A3B8'; ctx.font='10px "Outfit"';
  const numDates = isMobile ? 3 : 6;
  const stepDate = Math.floor((n - 1) / (numDates - 1));
  
  for(let i=0; i<numDates; i++) {
     let idx = (i === numDates - 1) ? n - 1 : i * stepDate;
     let x = toX(idx);
     
     ctx.textAlign = (i === 0) ? 'left' : (i === numDates - 1) ? 'right' : 'center';
     ctx.fillText(priceData[idx].date, x, H - (isMobile ? 12 : 8));
  }

  // Tooltip Logic
  const tooltip = document.getElementById('chartTooltip');
  
  const updateTooltip = (e, clientX, clientY) => {
    const rect = canvas.getBoundingClientRect();
    const mx = (clientX - rect.left) * (W / rect.width);
    let ci=0, md=Infinity;
    
    for(let i=0; i<n; i++){
        const d = Math.abs(toX(i) - mx);
        if(d < md) { md = d; ci = i; }
    }
    
    if(md > 35) { tooltip.style.display = 'none'; return; }
    
    const d = priceData[ci];
    tooltip.querySelector('.tt-date').textContent = d.date;
    tooltip.querySelector('.tt-close').textContent = '₹' + d.close.toFixed(2);
    tooltip.querySelector('.tt-close').style.color = d.close >= 111 ? '#00E5FF' : '#FF4D4D';
    tooltip.querySelector('.tt-high').textContent = '₹' + d.high.toFixed(2);
    tooltip.querySelector('.tt-low').textContent = '₹' + d.low.toFixed(2);
    tooltip.querySelector('.tt-vol').textContent = (d.vol / 1000).toFixed(0) + 'K';
    
    tooltip.style.display = 'block';
    
    let tx = clientX - container.getBoundingClientRect().left + 16;
    let ty = clientY - container.getBoundingClientRect().top - 40;
    
    if (tx + 180 > container.clientWidth) {
        tx = clientX - container.getBoundingClientRect().left - 196;
    }
    
    if (ty < 10) ty = 10;
    
    tooltip.style.left = tx + 'px'; 
    tooltip.style.top = ty + 'px';
  };

  canvas.onmousemove = e => updateTooltip(e, e.clientX, e.clientY);
  canvas.onmouseleave = () => tooltip.style.display = 'none';

  canvas.ontouchmove = e => {
    e.preventDefault();
    updateTooltip(e, e.touches[0].clientX, e.touches[0].clientY);
  };
  canvas.ontouchend = () => tooltip.style.display = 'none';
}

// ═══ OBSERVERS ═══
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if(entry.isIntersecting){
      const idx = Array.from(entry.target.parentElement?.children||[]).indexOf(entry.target);
      setTimeout(() => {
        entry.target.classList.add('visible');
        entry.target.querySelectorAll('.progress-fill').forEach(f => f.style.width=f.dataset.width+'%');
      }, Math.min(idx*80, 400));
    }
  });
}, {threshold:0.15, rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.anim,.card,.metric-box,.tl-item').forEach(el => observer.observe(el));

const slides = document.querySelectorAll('.slide');
const counter = document.getElementById('slideCounter');
const navLinks = document.querySelectorAll('.nav-link');

const slideObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if(e.isIntersecting){
      counter.textContent=`${e.target.dataset.slide} / ${slides.length}`;
      navLinks.forEach(l=>l.classList.remove('active'));
      document.querySelector(`.nav-link[href="#${e.target.id}"]`)?.classList.add('active');
    }
  });
}, { rootMargin: "-30% 0px -30% 0px", threshold: 0 }); 
slides.forEach(s => slideObs.observe(s));

navLinks.forEach(l=>l.addEventListener('click',()=>document.getElementById('navLinks').classList.remove('open')));

drawPriceChart();
window.addEventListener('resize', drawPriceChart);
</script>
</body>
